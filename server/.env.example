# CampusCrib — Environment Variables Template
# Copy this file to .env and fill in your values

# Server
PORT=3300

# MongoDB (use ATLASDB_URL for production)
MONGODB_URI=mongodb://127.0.0.1:27017/campuscrib
ATLASDB_URL=mongodb+srv://your-user:your-password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Cloudinary
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# Mapbox
MAP_TOKEN=your_mapbox_token

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id

# Session Secret
SESSION_SECRET=your_session_secret

# Production — set CLIENT_URL to your Vercel frontend URL when deploying
# CLIENT_URL=https://your-app.vercel.app
